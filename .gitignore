Set-Content -Path .gitignore -Value @"
# ==========================================
# MASTER THESIS .GITIGNORE
# ==========================================

# --- 1. DATA & ML ARTIFACTS (CRITICAL) ---
**/Data/
**/Experiment_Logs/
**/AutogluonModels/
**/catboost_info/
**/csv_backups/
*.pkl
*.pt
*.pth

# --- 2. PYTHON SYSTEM FILES & ENVIRONMENTS ---
__pycache__/
*.py[cod]
**/venv/
.env

# --- 3. IDE & TEMPORARY FILES ---
.qodo/
**/oldAnalyses/
New folder/

# --- 4. LATEX BUILD FILES ---
*.aux
*.bbl
*.bcf
*.blg
*.glo
*.ist
*.log
*.out
*.run.xml
*.synctex.gz
*.tdo
*.toc
*.fls
*.fdb_latexmk
*.bak
*~

# --- 5. OS GENERATED FILES ---
.DS_Store
Thumbs.db
"@